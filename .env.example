# API-Football v3 key (required)
API_FOOTBALL_KEY=your_api_key_here

# Master admin password (required)
MASTER_PASSWORD=change_me

# Port the server listens on (default: 3000)
PORT=3000

# Sync interval in minutes (default: 120)
SYNC_INTERVAL_MINUTES=120

# Session secret (auto-generated if not set)
SESSION_SECRET=
